{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true
  },
  "include": [
    "lib/types",
    "tests/lib/types",
    "packages/*/types",
    "packages/*/tests/types"
  ]
}
